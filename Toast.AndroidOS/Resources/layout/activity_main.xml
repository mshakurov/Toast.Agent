<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
		android:orientation="vertical"
    android:padding="20dp">


	<!-- Контейнер для кнопок вверху экрана -->
	<LinearLayout
			android:id="@+id/buttonContainer"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_alignParentTop="true"
			android:padding="2dp">

		<Button
				android:id="@+id/buttonStart"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/buttonStart"/>

		<Button
				android:id="@+id/buttonStop"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/buttonStop"/>

		<Button
				android:id="@+id/buttonSets"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/buttonSets"/>

	</LinearLayout>

	<!-- Контейнер для кнопок вверху экрана -->
	<LinearLayout
			android:id="@+id/buttonContainer2"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_below="@id/buttonContainer"
			android:padding="4dp">

		<Button
				android:id="@+id/buttonTestRequest"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/buttonTestRequest"/>

		<Button
				android:id="@+id/buttonTestShowMessage"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/buttonTestShowMessage"/>

		<Button
				android:id="@+id/buttonTestShowMessageService"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/buttonTestShowMessageService"/>

	</LinearLayout>

	<!-- Контейнер для кнопок вверху экрана -->
	<LinearLayout
			android:id="@+id/buttonContainer4"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_below="@id/buttonContainer"
			android:padding="4dp">

		<Button
				android:id="@+id/buttonTestBindToAgentService"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/buttonTestBindToAgentService"/>

		<Button
				android:id="@+id/buttonTestUnbindFromAgentService"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/buttonTestUnbindFromAgentService"/>

	</LinearLayout>

	<!-- Контейнер для кнопок вверху экрана -->
	<LinearLayout
			android:id="@+id/buttonContainer3"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_below="@id/buttonContainer"
			android:padding="4dp">

		<!-- Последняя кнопка выхода -->
		<Button
				android:id="@+id/buttonExit"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/buttonExit"
				android:focusable="true"
				android:focusableInTouchMode="true"/>

	</LinearLayout>

	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_weight="2"
		android:layout_below="@id/buttonsLayout"
		android:layout_alignParentBottom="true"
		android:layout_marginTop="12dp"
		android:textColor="#D5D5F5"
		android:scrollbars="vertical">
		<TextView
				android:id="@+id/app_text"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textIsSelectable="true"
				android:layout_below="@id/buttonContainer2"
				android:text="@string/app_text"
    />
	</ScrollView>

	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_weight="3"
		android:layout_below="@id/buttonsLayout"
		android:layout_alignParentBottom="true"
		android:layout_marginTop="12dp"
		android:background="#F5D5D5"
		android:scrollbars="vertical">
		<TextView
				android:id="@+id/perm_text"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textIsSelectable="true"
				android:layout_below="@id/buttonContainer2"
				android:text="@string/app_text"
    />
	</ScrollView>

</LinearLayout>