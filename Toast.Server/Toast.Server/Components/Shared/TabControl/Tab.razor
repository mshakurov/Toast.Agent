@code {
  [CascadingParameter]
  public TabControl? Parent { get; set; }

  [Parameter]
  [EditorRequired]
  public object? Name { get; set; } 

  [Parameter]
  public string? Title { get; set; }

  [Parameter]
  public string? Hint { get; set; } 

  [Parameter]
  public RenderFragment? ChildContent { get; set; }

  public string? NameStr => Name?.ToString();

  protected override void OnInitialized()
  {
    if ( Parent == null )
    {
      throw new ArgumentNullException( nameof( Parent ), "Компонент Tab должен быть внутри TabControl" );
    }
    if ( Name == null )
      throw new ArgumentNullException( "Tab.Name is null" );

    Parent.AddTab( this );
  }
}
