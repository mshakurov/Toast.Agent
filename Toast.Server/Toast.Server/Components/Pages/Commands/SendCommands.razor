@using Toast.Core.Commands.CommandData
@using Toast.Server.Api
@using Toast.Server.Components.Pages.Commands
@using Toast.Server.Data
@using Toast.Server.Components.Shared.TabControl;
@inject CommandService commandService;

<h4>Send Commands</h4>

<div class="form-control">

  <div class="form-row">
    <SelectClients @bind-SelectedClients="@commandService.Current.SelectedCommandClients" />
  </div>

  <div class="form-row">
    <TabControl ActiveTabOnStart="@commandService.Current.SendCommand_SelectedTab" OnActiveTabChanged="@(tab => commandService.Current.SendCommand_SelectedTab = tab)">
      <Tab Name="@PageComponents.ShowMessage" Title="ShowMessage">
        <ShowMessageCommand @bind-Data="@commandService.Current.ShowMessageData">
          <button type="button" class="btn btn-primary btn-sm" disabled="@sending" onclick="@(async () => await SendCommand( commandService.Current.ShowMessageData, Core.Commands.CommandTypes.ShowMessage ))">Send command</button>
        </ShowMessageCommand>
      </Tab>
      <Tab Name="@PageComponents.ChangeSettings" Title="ChangeSettings">
        <ChangeSettingsCommand @bind-Data="@commandService.Current.ChangeSettingsData">
          <button type="button" class="btn btn-primary btn-sm" disabled="@sending" onclick="@(async () => await SendCommand( commandService.Current.ChangeSettingsData, Core.Commands.CommandTypes.ChangeSettings ))">Send command</button>
        </ChangeSettingsCommand>
      </Tab>
      <Tab Name="@PageComponents.GetDeviceInfo" Title="GetDeviceInfo">
        <button type="button" class="btn btn-primary btn-sm" onclick="@(async () => await SendCommand( null, Core.Commands.CommandTypes.GetDeviceInfo ))" title="Запросить информацию по выделенным устройствам"><i class="bi bi-cloud-download-fill"></i></button>
      </Tab>
    </TabControl>
  </div>

  @if ( alert != null )
  {
    <div class="form-row">
      <textarea class="form-control text-bg-warning" rows="@alertRows" @bind="@alert"></textarea>
    </div>
  }

</div>

@code {

  enum PageComponents
  {
    ShowMessage,
    ChangeSettings,
    GetDeviceInfo,
  }

  string? alert = null;
  int alertRows = 3;
  bool sending = false;

  protected override async Task OnInitializedAsync()
  {
    await base.OnInitializedAsync();

    if ( commandService.Current.SendCommand_SelectedTab == null )
      commandService.Current.SendCommand_SelectedTab = PageComponents.ShowMessage;
  }

  async Task SendCommand( object? data, string commandType )
  {
    await Task.CompletedTask;

    if ( @commandService.Current.SelectedCommandClients.Count == 0 )
    {
      ShowAlert( "Не выбраны клиенты!", 5, 1 );
      return;
    }

    alert = null;
    sending = true;
    StateHasChanged();

    _ = Task.Run( async () =>
    {
      try
      {
        CommandDataBase clone = data is ShowMessageData showMessageData ? showMessageData.CloneEx()
          : data is ChangeSettingsData settingsData ? settingsData.CloneEx()
          : commandType == Core.Commands.CommandTypes.GetDeviceInfo ? new()
          : throw new Exception( "### Program error - unsupported command data type" );

        var commands = await commandService.EnqueueCommandAsync( @commandService.Current.SelectedCommandClients, commandType, clone );

        await commandService.UpdatePredefinedServers();

        ShowAlert( $"Команда успешно поставлена в очередь для {commands.Count} клиентов", 5, 1 );
      }
      catch ( Exception ex )
      {
        alert = $"Ошибка отправки команд: {ex}";
        alertRows = 5;
        StateHasChanged();
      }
      finally
      {
        sending = false;
        await InvokeAsync( StateHasChanged );
      }
    } );
  }


  void ShowAlert( string msg, int seconds = 5, int rows = 3 )
  {
    InvokeAsync( () =>
    {
      alert = msg;
      alertRows = rows;
      StateHasChanged();

      Task.Delay( TimeSpan.FromSeconds( seconds ) ).ContinueWith( _ =>
      {
        alert = null;
        _ = InvokeAsync( StateHasChanged );
      } );
    } );
  }
}
