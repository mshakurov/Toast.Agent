@using Toast.Server.Data
@using Toast.Server.Data.Models
@inject CommandService commandService;

<button class="btn btn-outline-info btn-sm" @onclick="@RefreshClients" title="Обновить"><i class="bi bi-arrow-clockwise"></i></button>
@if ( agentClients == null )
{
  <div>чтение клиентов ...</div>
}
else
{
  <Toast.Server.Components.Shared.MyTable.TableMy TItem="AgentClientUI" Compact Items="agentClients" Border>
    <TableHeader>
      <th>Выбран</th>
      <th>@nameof( AgentClient.ClientId )</th>
      <th>@nameof( AgentClient.LastGet )</th>
      <th>@nameof( AgentClient.LastSet )</th>
    </TableHeader>
    <TableRow>
      @{
        var agentUI = context;
        var selected = agentUI.Selected;
      }
      <td><input type="checkbox" class="form-check" checked="@selected" @onchange="@(async args => await OnSelectChanged( @agentUI, args ))"></td>
      <td @onclick="@(async args => await OnSelectChanged( @agentUI, null ))">@agentUI.Client.ClientId</td>
      <td>@agentUI.Client.LastGet</td>
      <td>@agentUI.Client.LastSet</td>
    </TableRow>
  </Toast.Server.Components.Shared.MyTable.TableMy>
}

@code {

  [Parameter]
  public List<string> SelectedClients { get; set; } = [];

  // Шаблон имени строго: ИмяПараметра + Changed
  [Parameter]
  public EventCallback<List<string>> SelectedClientsChanged { get; set; }

  string[] GetSelectedClientIds => agentClients?.Where( c => c.Selected ).Select( c => c.Client.ClientId ).ToArray() ?? [];

  AgentClientUI[]? agentClients = null;
  string? loadClientsError = null;

  class AgentClientUI
  {
    public readonly AgentClient Client;
    public readonly string LastGetStr;
    public readonly string LastSetStr;

    public AgentClientUI( AgentClient client )
    {
      Client = client;
      LastGetStr = client.LastGet.ToString( "s" );
      LastSetStr = client.LastSet?.ToString( "s" ) ?? string.Empty;
    }

    public bool Selected { get; set; }
  }

  protected override async Task OnInitializedAsync()
  {
    await base.OnInitializedAsync();

    commandService.ClientAddedEvent += OnClientAdded;
  }

  protected override async Task OnParametersSetAsync()
  {
    await base.OnParametersSetAsync();

    await RefreshClients();
  }

  async Task RefreshClients()
  {
    loadClientsError = null;
    try
    {
      agentClients = ( await commandService.GetAllAgentClients() ).Select( c => new AgentClientUI( c ) { Selected = SelectedClients.Contains( c.ClientId ) } ).OrderBy( c => c.Selected ? 1 : 2 ).ThenByDescending( c => c.Client.LastSet ?? c.Client.LastGet ).ToArray();
    }
    catch ( Exception ex )
    {
      loadClientsError = $"{ex.Message}|{ex.InnerException?.Message}|{ex.InnerException?.InnerException?.Message}";

      agentClients = null;
    }
  }

  async Task OnSelectChanged( AgentClientUI clientUI, ChangeEventArgs? args )
  {
    clientUI.Selected = args != null && args.Value is bool _bool ? _bool : !clientUI.Selected;

    agentClients = agentClients?.OrderBy( c => c.Selected ? 1 : 2 ).ThenByDescending( c => c.Client.LastSet ?? c.Client.LastGet ).ToArray();

    if ( clientUI.Selected )
      await SelectedClientsChanged.InvokeAsync( SelectedClients = SelectedClients.Union( [clientUI.Client.ClientId] ).ToList() );
    else
      await SelectedClientsChanged.InvokeAsync( SelectedClients = SelectedClients.Except( [clientUI.Client.ClientId] ).ToList() );
  }

  void OnClientAdded( object? sender, string clientId )
  {
    _ = Task.Run( () => RefreshClients().ContinueWith( _ => InvokeAsync( StateHasChanged ) ).Wait() );
  }
}
